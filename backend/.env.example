PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flight_tracker"

# REQUIRED — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 cryptographically random bytes. Never commit a real value.
JWT_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET

FRONTEND_ORIGIN=http://localhost:5173

# Admin seed credentials — change BOTH before running `npm run prisma:seed`.
# Password must be at least 12 characters.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
