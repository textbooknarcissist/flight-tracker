{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["server.ts", "src/**/*.ts", "src/**/*.d.ts", "prisma/**/*.ts", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
