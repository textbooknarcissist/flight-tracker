{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "server.ts",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "prisma/**/*.ts",
    "tests/**/*.ts",
    "../shared/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
